# Copy to .env (or export these) and fill in. Nothing here is committed.

# --- SEC (required by SEC policy: a descriptive contact User-Agent) ---
SEC_USER_AGENT="YourName your-email@example.com"

# --- Scanner tunables ---
SCANNER_MIN_SCORE=50        # 0-100 alert threshold
SCANNER_INTERVAL=300        # seconds between scans in --loop mode
# SCANNER_DB=/data/scanner.db   # keep the DB on a persistent disk in production

# --- Congressional trade feeds (GitHub raw JSON; defaults work no-key) ---
# Point SENATE_TRADES_URL at YOUR fork of legislative-alpha for a pipeline you own.
# See README "Live Senate data (your own fork)".
# HOUSE_TRADES_URL=https://raw.githubusercontent.com/TattooedHead/house-stock-watcher-data/master/data/all_transactions.json
# SENATE_TRADES_URL=https://raw.githubusercontent.com/<you>/legislative-alpha/HEAD/data.json

# --- Phone-app API (api.py) ---
SCANNER_CORS_ORIGINS=*      # lock to your domain in production, e.g. https://scanner.example

# --- Web Push (push.py) — generate with:  python push.py --generate-keys ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL="you@example.com"

# --- Optional extra alert channels (console always works with none of these) ---
# PUSHOVER_TOKEN=
# PUSHOVER_USER=
# DISCORD_WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
